	{0,                             XF86XK_AudioLowerVolume, spawn, NOTIFY("vol_down")},
	{0,                             XF86XK_AudioMute, spawn, NOTIFY("vol_mute")},
	{0,                             XF86XK_AudioMicMute, spawn, NOTIFY("mic_mute")},
	{ MODKEY|ShiftMask, XK_f, spawn, {.v = firefoxcmd } },
	{ MODKEY|ShiftMask, XK_t, spawn, {.v = telegramcmd } },
	{ MODKEY|ShiftMask, XK_o, spawn, {.v = obsidiancmd } },
	{0,                 XK_Print, spawn, {.v = flameshot } },
	{MODKEY|ShiftMask, XK_m, spawn, {.v = btopcmd } },
	{MODKEY|ShiftMask, XK_e, spawn, {.v = yazicmd } },	
	{MODKEY,          XK_v, spawn, {.v = syscontrolcmd } },

