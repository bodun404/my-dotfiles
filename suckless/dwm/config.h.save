#include <X11/XF86keysym.h>
#define NOTIFY(cmd) SHCMD("~/.config/sys-notify.sh " cmd)

/* appearance */
static const unsigned int borderpx  = 1;        /* border pixel of windows */
static const unsigned int snap      = 32;       /* snap pixel */
static const int showbar            = 1;        /* 0 means no bar */
static const int topbar             = 0;        /* 0 means bottom bar */
static const unsigned int systraypinning = 0; /* 0: focus, >0: pin tray to monitor X */
static const unsigned int systrayonleft = 0; /* 0: tray right after text, >0: tray left */
static const unsigned int systrayspacing = 2; /* spacing beetween icons in px */
static const int systraypinningfailfirst = 1; /*1: if failed to pin, show on first monitor */
static const int showsystray = 1; /*if 0 - tray disabled */
static const int smartgaps = 0; /* 1 - there are no gapps if only 1 window open */
static const unsigned int gappih = 10; /* horizontal gapp */
static const unsigned int gappiv = 10; /* vertical gapp */
static const unsigned int gappoh = 10; /* out horizontal gapp */
static const unsigned int gappov = 10; /* out vertical gapp */
